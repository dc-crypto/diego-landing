{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "diego-landing",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./out"
  },
  "routes": [
    { "pattern": "diegocastro.tech/*", "zone_name": "diegocastro.tech" }
  ]
}
